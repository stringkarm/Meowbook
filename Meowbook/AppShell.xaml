<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Meowbook.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Meowbook.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Home" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}" Route="HomePage" />
        </Tab>
        <Tab Title="Search" Icon="search_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:SearchPage}" Route="SearchPage" />
        </Tab>
        <Tab Title="Add" Icon="add_post.png">
            <ShellContent ContentTemplate="{DataTemplate views:AddPostPage}" Route="AddPostPage" />
        </Tab>
        <Tab Title="Profile" Icon="profile_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" Route="ProfilePage" />
        </Tab>
        <Tab Title="Menu" Icon="menu.png">
            <ShellContent ContentTemplate="{DataTemplate views:MenuPage}" Route="MenuPage" />
        </Tab>
    </TabBar>

</Shell>
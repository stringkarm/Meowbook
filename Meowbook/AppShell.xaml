<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Meowbook.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Meowbook.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Meowbook"
    Shell.NavBarHasShadow="False">

    <ShellContent
        ContentTemplate="{DataTemplate views:LandingPage}"
        Route="LandingPage" />

    <ShellContent
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage" />

    <ShellContent
        ContentTemplate="{DataTemplate views:ForgotPassword}"
        Route="ForgotPassword" />

    <ShellContent
        ContentTemplate="{DataTemplate views:RegistrationPage}"
        Route="RegistrationPage" />

    <ShellContent
        ContentTemplate="{DataTemplate views:HomePage}"
        Route="HomePage"/>

</Shell>
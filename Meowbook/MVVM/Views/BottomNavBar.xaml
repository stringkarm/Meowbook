<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meowbook.Views.BottomNavBar"
             BackgroundColor="Transparent">

    <!-- Outer Grid: bar + overlapping FAB -->
    <Grid HeightRequest="100" BackgroundColor="Transparent"> <!-- Increased slightly to fit text and pill bottom margin -->

        <!-- White pill bar at the bottom -->
        <Border Margin="16,25,16,15"
                BackgroundColor="White"
                StrokeThickness="0"
                VerticalOptions="Fill">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.10" Radius="10" Offset="0,4"/>
            </Border.Shadow>

            <!-- 5 columns: Home | Search | [FAB gap] | Profile | Menu -->
            <Grid ColumnDefinitions="*,*,68,*,*" Padding="0,5,0,5">

                <!-- HOME -->
                <StackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label x:Name="HomeIcon" Text="⌂" FontSize="24" HorizontalOptions="Center" TextColor="#BBBBBB"/>
                    <Label x:Name="HomeText" Text="Home" FontSize="11" HorizontalOptions="Center" TextColor="#BBBBBB"/>
                    <StackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped"/>
                    </StackLayout.GestureRecognizers>
                </StackLayout>

                <!-- SEARCH -->
                <StackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label x:Name="SearchIcon" Text="🔍" FontSize="20" HorizontalOptions="Center" TextColor="#BBBBBB"/>
                    <Label x:Name="SearchText" Text="Search" FontSize="11" HorizontalOptions="Center" TextColor="#BBBBBB"/>
                    <StackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSearchTapped"/>
                    </StackLayout.GestureRecognizers>
                </StackLayout>

                <!-- Center spacer for FAB -->
                <BoxView Grid.Column="2" Color="Transparent"/>

                <!-- PROFILE -->
                <StackLayout Grid.Column="3" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label x:Name="ProfileIcon" Text="👤" FontSize="20" HorizontalOptions="Center" TextColor="#BBBBBB"/>
                    <Label x:Name="ProfileText" Text="Profile" FontSize="11" HorizontalOptions="Center" TextColor="#BBBBBB"/>
                    <StackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTapped"/>
                    </StackLayout.GestureRecognizers>
                </StackLayout>

                <!-- MENU -->
                <StackLayout Grid.Column="4" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label x:Name="MenuIcon" Text="☰" FontSize="24" HorizontalOptions="Center" TextColor="#BBBBBB"/>
                    <Label x:Name="MenuText" Text="Menu" FontSize="11" HorizontalOptions="Center" TextColor="#BBBBBB"/>
                    <StackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </StackLayout.GestureRecognizers>
                </StackLayout>

            </Grid>
        </Border>

        <!-- FAB — overlaps the bar from above -->
        <Border WidthRequest="62"
                HeightRequest="62"
                BackgroundColor="#A64BFF"
                Stroke="White"
                StrokeThickness="4"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                Margin="0,0,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="31"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#A64BFF" Opacity="0.4" Radius="10" Offset="0,4"/>
            </Border.Shadow>
            <Label Text="+"
                   FontSize="34"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="0,-3,0,0"/>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnFabTapped"/>
            </Border.GestureRecognizers>
        </Border>

    </Grid>
</ContentView>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Meowbook.ViewModels"
             xmlns:models="clr-namespace:Meowbook.Models"
             xmlns:views="clr-namespace:Meowbook.Views"
             x:Class="Meowbook.Views.SearchPage"
             x:DataType="vm:SearchViewModel"
             Title="Search Users"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, *">
        <SearchBar Grid.Row="0"
                   Text="{Binding SearchText}"
                   SearchCommand="{Binding PerformSearchCommand}"
                   Placeholder="Search by name or username..."
                   Margin="10" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding SearchResults}" Margin="10,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:User">
                    <Frame Margin="0,0,0,10" Padding="15" CornerRadius="10" BorderColor="Transparent" BackgroundColor="White">
                        <HorizontalStackLayout Spacing="15">
                            <Frame Padding="0" HeightRequest="50" WidthRequest="50" CornerRadius="25" IsClippedToBounds="True" BorderColor="#1DA1F2">
                                <Image Source="{Binding Avatar}" Aspect="AspectFill"/>
                            </Frame>
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#1A1A2E"/>
                                <Label Text="{Binding Username, StringFormat='@{0}'}" FontSize="13" TextColor="Gray"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" VerticalOptions="Center"/>

        <!-- General Bottom Nav Bar -->
        <views:BottomNavBar Grid.Row="1" ActiveTab="Search" VerticalOptions="End" />

    </Grid>
</ContentPage>
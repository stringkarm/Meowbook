<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Meowbook.ViewModels"
             x:Class="Meowbook.Views.RegistrationPage"
             x:DataType="vm:RegistrationViewModel"
             BackgroundColor="#F5F5F5"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="180, *">
        <BoxView Grid.Row="0" BackgroundColor="#FF8C00" />
        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
            <Label Text="Create Account" 
                   FontFamily="PoppinsBold"
                   TextColor="White" 
                   FontSize="32" 
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
            <Label Text="Join the community of cat lovers!" 
                   TextColor="White" 
                   FontFamily="InterRegular"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <Frame Grid.Row="1" 
               Margin="0,-30,0,0" 
               CornerRadius="30" 
               Padding="25" 
               BorderColor="LightGray" 
               HasShadow="True" 
               BackgroundColor="White">

            <ScrollView>
                <VerticalStackLayout Spacing="15">

                    <Border Stroke="#FF8C00">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry Text="{Binding Name}" 
                               Placeholder="Full Name" 
                               HeightRequest="55" 
                               TextColor="Black"
                               FontFamily="InterRegular" />
                    </Border>

                    <Border Stroke="#FF8C00">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry Text="{Binding Username}" 
                               Placeholder="Username (Login ID)" 
                               HeightRequest="55" 
                               TextColor="Black"
                               FontFamily="InterRegular" />
                    </Border>

                    <Border Stroke="#FF8C00">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry Text="{Binding Email}" 
                               Placeholder="Email Address" 
                               HeightRequest="55" 
                               TextColor="Black"
                               Keyboard="Email"
                               FontFamily="InterRegular" />
                    </Border>

                    <Border Stroke="#FF8C00">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto">
                            <Entry x:Name="RegPasswordEntry"
                                   Text="{Binding Password}" 
                                   Placeholder="Password" 
                                   IsPassword="True" 
                                   HeightRequest="55" 
                                   TextColor="Black"
                                   FontFamily="InterRegular" />
                            <Button Grid.Column="1" Text="👁" TextColor="Gray" BackgroundColor="Transparent" FontSize="20" Margin="0,0,10,0"
                                         VerticalOptions="Center" Clicked="OnToggleRegPasswordClicked" />
                        </Grid>
                    </Border>

                    <Border Stroke="#FF8C00">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry Text="{Binding Birthdate}"
                               Placeholder="Birthdate (MM/DD/YYYY)" 
                               HeightRequest="55"
                               TextColor="Black"
                               FontFamily="InterRegular" />
                    </Border>

                    <Button Text="Register Now" 
                            FontFamily="PoppinsMedium"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="#FF8C00" 
                            TextColor="White"
                            HeightRequest="60" 
                            CornerRadius="12"
                            Margin="0,10,0,0" />

                    <Button Text="Already have an account? Login"
                            FontFamily="InterRegular"
                            BackgroundColor="Transparent"
                            TextColor="Gray"
                            FontSize="13"
                            Command="{Binding GoToLoginCommand}" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                       IsVisible="{Binding IsBusy}"
                                       Color="#FF8C00" 
                                       HorizontalOptions="Center" />

                </VerticalStackLayout>
            </ScrollView>
        </Frame>
    </Grid>
</ContentPage>
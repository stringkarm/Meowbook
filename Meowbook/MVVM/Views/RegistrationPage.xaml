<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Meowbook.ViewModels"
             x:Class="Meowbook.Views.RegistrationPage"
             x:DataType="vm:RegistrationViewModel"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <Image Source="bg.png" 
               Aspect="AspectFill" 
               HorizontalOptions="Fill" 
               VerticalOptions="Fill" />

        <ScrollView>
            <VerticalStackLayout Spacing="15" Padding="20,10,20,20">

                <Grid ColumnDefinitions="40, *" VerticalOptions="Start" Margin="0,5,0,10">
                    <Border Grid.Column="0" 
                            BackgroundColor="#40FFFFFF" 
                            Stroke="#60FFFFFF" 
                            StrokeThickness="0.5" 
                            HeightRequest="40" 
                            WidthRequest="40" 
                            HorizontalOptions="Start"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <ImageButton Source="back.png" 
                                     HeightRequest="10" 
                                     WidthRequest="10"
                                     Padding="8"
                                     Margin="-3,-3,0,0"
                                     Aspect="AspectFit"
                                     BackgroundColor="Transparent"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Clicked="OnBackClicked"/>
                    </Border>

                    <Label Grid.Column="1"
                           Text="Create an Account" 
                           TextColor="White" 
                           FontSize="22" 
                           FontFamily="PoppinsBold"
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"
                           Margin="0,0,40,0" />
                </Grid>

                <Label Text="Join the community of cat lovers!" 
                       TextColor="White" 
                       HorizontalTextAlignment="Center" 
                       Opacity="0.8"
                       FontSize="14"
                       Margin="0,0,0,10"
                       FontFamily="InterRegular"/>

                <Border Stroke="White" StrokeThickness="0.5" BackgroundColor="#40FFFFFF">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Entry Text="{Binding Name}" 
                           Placeholder="Full Name" 
                           PlaceholderColor="#E0E0E0"
                           HeightRequest="55" 
                           TextColor="White"
                           Margin="15,0"/>
                </Border>

                <Border Stroke="White" StrokeThickness="0.5" BackgroundColor="#40FFFFFF">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Entry Text="{Binding Username}" 
                           Placeholder="Username" 
                           PlaceholderColor="#E0E0E0"
                           HeightRequest="55" 
                           TextColor="White"
                           Margin="15,0"/>
                </Border>

                <Border Stroke="White" StrokeThickness="0.5" BackgroundColor="#40FFFFFF">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Entry Text="{Binding Email}" 
                           Placeholder="Email Address" 
                           PlaceholderColor="#E0E0E0"
                           Keyboard="Email"
                           HeightRequest="55" 
                           TextColor="White"
                           Margin="15,0"/>
                </Border>

                <Border Stroke="White" StrokeThickness="0.5" BackgroundColor="#40FFFFFF">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*, 45">
                        <Entry x:Name="RegPasswordEntry" 
                               Text="{Binding Password}"
                               Placeholder="Password" 
                               IsPassword="True" 
                               PlaceholderColor="#E0E0E0"
                               HeightRequest="55" 
                               TextColor="White"
                               Margin="15,0"/>
                        <ImageButton Grid.Column="1" 
                                     Source="seepassword.png" 
                                     BackgroundColor="Transparent" 
                                     HeightRequest="24" 
                                     WidthRequest="24"
                                     Aspect="AspectFit"
                                     VerticalOptions="Center" 
                                     Clicked="OnToggleRegPasswordClicked" />
                    </Grid>
                </Border>

                <Border Stroke="White" StrokeThickness="0.5" BackgroundColor="#40FFFFFF">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Entry Text="{Binding Birthdate}" 
                           Placeholder="Birthdate (MM/DD/YYYY)" 
                           PlaceholderColor="#E0E0E0"
                           HeightRequest="55" 
                           TextColor="White"
                           Margin="15,0"/>
                </Border>

                <Button Text="Register Now" 
                        BackgroundColor="#FF8C00" 
                        TextColor="White"
                        HeightRequest="60" 
                        CornerRadius="20" 
                        Margin="0,15,0,5" 
                        FontFamily="PoppinsMedium"
                        Command="{Binding RegisterCommand}" />

                <HorizontalStackLayout HorizontalOptions="Center" Margin="0,10,0,0">
                    <Label Text="Already have an account? " TextColor="White" VerticalOptions="Center" FontSize="13" />
                    <Label Text="Login" 
                           TextColor="White" 
                           FontAttributes="Bold" 
                           VerticalOptions="Center"
                           Padding="10,10"
                           FontSize="13">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackClicked" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                   IsVisible="{Binding IsBusy}"
                                   Color="White" 
                                   HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meowbook.Views.UserProfilePage"
             BackgroundColor="#F5F5F5"
             Title="Profile">
             
    <ScrollView>
        <StackLayout Padding="20">
            <Border WidthRequest="100" HeightRequest="100" StrokeThickness="0" HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="50"/>
                </Border.StrokeShape>
                <Image x:Name="ProfileImage" Aspect="AspectFill" BackgroundColor="LightGray" />
            </Border>
            <Label x:Name="NameLabel" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,10,0,0"/>
            <Label x:Name="UsernameLabel" FontSize="14" TextColor="#888" HorizontalOptions="Center"/>

            <Button x:Name="FollowBtn" Text="Follow" BackgroundColor="#1DA1F2" TextColor="White" Margin="0,20,0,0" CornerRadius="20" WidthRequest="120" Clicked="OnFollowClicked"/>
            
            <!-- Feed for this user could go here -->
            <Label Text="Posts" FontSize="18" FontAttributes="Bold" Margin="0,30,0,10"/>
            <Label Text="No posts yet." TextColor="#888"/>
        </StackLayout>
    </ScrollView>
</ContentPage>

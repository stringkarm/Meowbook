<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meowbook.Views.LandingPage"
             BackgroundColor="#FF8C00"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*, Auto">
        <VerticalStackLayout Grid.Row="0" VerticalOptions="Center" Spacing="20">
            <Image Source="getstarted.png" Aspect="Fill" HeightRequest="350" WidthRequest="380" Margin="0,50,20,20"/>
        </VerticalStackLayout>

        <Frame Grid.Row="1" BackgroundColor="White" CornerRadius="30" Margin="0,-0,0,-30" Padding="50,40" BorderColor="LightGray">
            <VerticalStackLayout Spacing="20">
                <Label Text="The ultimate community for cat lovers"
                       FontSize="24" FontFamily="PoppinsBold" FontAttributes="Bold"
                       TextColor="#1C1C1C" HorizontalTextAlignment="Center" />

                <Label Text="Ready to start your journey?" 
                       TextColor="Gray" HorizontalOptions="Center" FontFamily="InterRegular"/>

                <Button Text="Get Started"
                        Clicked="OnGetStartedClicked"
                        BackgroundColor="#FF8C00" TextColor="White"
                        HeightRequest="60" CornerRadius="12" 
                        FontFamily="PoppinsMedium" FontSize="18" Margin="0,40"/>
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
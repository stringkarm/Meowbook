<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meowbook.Views.LandingPage"
             BackgroundColor="#FF8C00"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <Image Source="landingpagebg.png" 
               Aspect="AspectFill" 
               HorizontalOptions="Fill" 
               VerticalOptions="Fill" />

        <VerticalStackLayout Spacing="20" Padding="50,40" VerticalOptions="End">

            <Label Text="The ultimate community for cat lovers"
                   FontSize="24" 
                   FontFamily="PoppinsBold" 
                   FontAttributes="Bold"
                   TextColor="#1C1C1C" 
                   HorizontalTextAlignment="Center" />

            <Label Text="Ready to start your journey?" 
                   TextColor="Gray" 
                   HorizontalOptions="Center" 
                   FontFamily="InterRegular"/>

            <Button Text="Get Started"
                    Clicked="OnGetStartedClicked"
                    BackgroundColor="#FF8C00" 
                    TextColor="White"
                    HeightRequest="60" 
                    CornerRadius="20" 
                    FontFamily="PoppinsMedium" 
                    FontSize="18" 
                    Margin="0,40"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
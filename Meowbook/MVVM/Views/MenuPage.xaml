<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meowbook.Views.MenuPage"
             BackgroundColor="#F0F0F0"
             Title="Menu">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Frame BackgroundColor="White" Padding="15" CornerRadius="10" HasShadow="False">
                <HorizontalStackLayout Spacing="15">
                    <Image Source="profile.png" HeightRequest="60" WidthRequest="60"/>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Cat Parent Name" FontSize="20" FontAttributes="Bold" FontFamily="Poppins"/>
                        <Label Text="See your profile" TextColor="Gray" FontFamily="Inter"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>

            <Label Text="Settings &amp; Privacy" FontAttributes="Bold" Margin="5,10,0,0" FontFamily="Poppins"/>

            <Frame BackgroundColor="White" Padding="0" CornerRadius="10" HasShadow="False">
                <VerticalStackLayout>
                    <Button Text="Settings" TextColor="Black" BackgroundColor="Transparent" HorizontalOptions="Start" FontFamily="Inter"/>
                    <BoxView HeightRequest="1" Color="#F0F0F0"/>
                    <Button Text="Help &amp; Support" TextColor="Black" BackgroundColor="Transparent" HorizontalOptions="Start" FontFamily="Inter"/>
                    <BoxView HeightRequest="1" Color="#F0F0F0"/>
                    <Button Text="Privacy Shortcuts" TextColor="Black" BackgroundColor="Transparent" HorizontalOptions="Start" FontFamily="Inter"/>
                    <BoxView HeightRequest="1" Color="#F0F0F0"/>
                    <Button Text="Terms of Service" TextColor="Black" BackgroundColor="Transparent" HorizontalOptions="Start" FontFamily="Inter"/>
                </VerticalStackLayout>
            </Frame>

            <Button Text="Log Out" 
                    BackgroundColor="Black" 
                    TextColor="Orange" 
                    FontAttributes="Bold" 
                    Margin="0,20,0,0"
                    FontFamily="Poppins"
                    Clicked="OnLogoutClicked"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
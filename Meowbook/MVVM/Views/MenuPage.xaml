<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Meowbook.Views"
             x:Class="Meowbook.Views.MenuPage"
             Title="Menu"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="15">
                <Frame Padding="15" CornerRadius="12" BackgroundColor="White" BorderColor="Transparent" HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnViewProfileClicked" />
                    </Frame.GestureRecognizers>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroupList>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#F0F0F0" />
                                        <Setter Property="Scale" Value="0.98" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateGroupList>
                    </VisualStateManager.VisualStateGroups>
                    <HorizontalStackLayout Spacing="15">
                        <Border Padding="0" HeightRequest="60" WidthRequest="60" Stroke="#A64BFF" StrokeThickness="2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="30"/>
                            </Border.StrokeShape>
                            <Image x:Name="MenuProfileImage" Aspect="AspectFill"/>
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label x:Name="MenuNameLabel" FontSize="20" FontAttributes="Bold" TextColor="#1C1C1C"/>
                            <Label Text="Welcome back!" TextColor="#A64BFF" FontSize="14" FontAttributes="Italic"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>

                <Label Text="Quick Links" FontAttributes="Bold" FontSize="16" Margin="0,10,0,5"/>

                <Button Text="Edit Profile" Clicked="OnEditProfileClicked" BackgroundColor="White" TextColor="Black"/>
                <Button Text="Settings &amp; Privacy" Clicked="OnSettingsClicked" BackgroundColor="White" TextColor="Black"/>
                <Button Text="Help &amp; Support" BackgroundColor="White" TextColor="Black" Clicked="OnHelpClicked"/>
                <Button Text="Terms of Service" BackgroundColor="White" TextColor="Black" Clicked="OnTermsClicked"/>

                <Button Text="Log Out" Command="{Binding LogoutCommand}" 
                        BackgroundColor="#FF8C00" Margin="0,30,0,0" Clicked="OnLogoutClicked" TextColor="White"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- General Bottom Nav Bar -->
        <views:BottomNavBar ActiveTab="Menu" VerticalOptions="End" />
    </Grid>
</ContentPage>
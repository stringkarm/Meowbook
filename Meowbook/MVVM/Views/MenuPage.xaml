<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Meowbook.Views"
             x:Class="Meowbook.Views.MenuPage"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*" Padding="0">
        
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="0,20,0,10">
            <Label Text="Menu" FontFamily="PoppinsBold" FontSize="20" HorizontalOptions="Center" TextColor="Black"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="25">
                
                <!-- Profile Card -->
                <Border BackgroundColor="#E0E0E0" Padding="15" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnViewProfileClicked"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Border Padding="0" HeightRequest="60" WidthRequest="60" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="30"/>
                            </Border.StrokeShape>
                            <Image x:Name="MenuProfileImage" Aspect="AspectFill" Source="profileplaceholder.png"/>
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label x:Name="MenuNameLabel" Text="Full name here" FontFamily="PoppinsRegular" FontSize="18" TextColor="#1C1C1C" FontAttributes="Bold"/>
                            <Label Text="See Profile" FontFamily="PoppinsRegular" FontSize="14" TextColor="#4B4B4B"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <!-- More Section -->
                <VerticalStackLayout Spacing="15">
                    <Label Text="More" FontFamily="PoppinsBold" FontSize="18" TextColor="Black" Margin="0,5"/>

                    <!-- Edit Profile -->
                    <HorizontalStackLayout Spacing="15" Padding="0,5">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEditProfileClicked"/>
                        </HorizontalStackLayout.GestureRecognizers>
                        <Image Source="edit.png" HeightRequest="35" WidthRequest="35" VerticalOptions="Center"/>
                        <Label Text="Edit Profile" FontFamily="PoppinsRegular" FontSize="16" TextColor="Black" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Settings and Privacy -->
                    <HorizontalStackLayout Spacing="15" Padding="0,5">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSettingsClicked"/>
                        </HorizontalStackLayout.GestureRecognizers>
                        <Image Source="settings.png" HeightRequest="35" WidthRequest="35" VerticalOptions="Center"/>
                        <Label Text="Settings and Privacy" FontFamily="PoppinsRegular" FontSize="16" TextColor="Black" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Help -->
                    <HorizontalStackLayout Spacing="15" Padding="0,5">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHelpClicked"/>
                        </HorizontalStackLayout.GestureRecognizers>
                        <Image Source="help.png" HeightRequest="35" WidthRequest="35" VerticalOptions="Center"/>
                        <Label Text="Help" FontFamily="PoppinsRegular" FontSize="16" TextColor="Black" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Support -->
                    <HorizontalStackLayout Spacing="15" Padding="0,5">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHelpClicked"/>
                        </HorizontalStackLayout.GestureRecognizers>
                        <Image Source="support.png" HeightRequest="35" WidthRequest="35" VerticalOptions="Center"/>
                        <Label Text="Support" FontFamily="PoppinsRegular" FontSize="16" TextColor="Black" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Terms of Service -->
                    <HorizontalStackLayout Spacing="15" Padding="0,5">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTermsClicked"/>
                        </HorizontalStackLayout.GestureRecognizers>
                        <Image Source="terms.png" HeightRequest="35" WidthRequest="35" VerticalOptions="Center"/>
                        <Label Text="Terms of Service" FontFamily="PoppinsRegular" FontSize="16" TextColor="Black" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Log out -->
                    <HorizontalStackLayout Spacing="15" Padding="0,5">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogoutClicked"/>
                        </HorizontalStackLayout.GestureRecognizers>
                        <Image Source="logout.png" HeightRequest="35" WidthRequest="35" VerticalOptions="Center">
                            <!-- Could potentially apply a red tint if needed -->
                        </Image>
                        <Label Text="Log out" FontFamily="PoppinsRegular" FontSize="16" TextColor="#FF3B30" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- General Bottom Nav Bar (Assumed is handled by AppShell or needs to be here) -->
        <views:BottomNavBar Grid.Row="1" ActiveTab="Menu" VerticalOptions="End" />
    </Grid>
</ContentPage>
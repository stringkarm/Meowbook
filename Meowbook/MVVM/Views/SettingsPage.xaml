<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meowbook.Views.SettingsPage"
             BackgroundColor="#F5F5F5"
             Shell.NavBarIsVisible="False">
             
    <Grid RowDefinitions="Auto, *">
        <!-- Header Section (Orange) -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="#FF8C00" Padding="20,30,20,40" Spacing="20">
            <Grid ColumnDefinitions="40, *, 40">
                <ImageButton Grid.Column="0" Source="back.png" HeightRequest="20" WidthRequest="20" Clicked="OnBackClicked" BackgroundColor="Transparent" Padding="0" HorizontalOptions="Start"/>
                <Label Grid.Column="1" Text="Settings &amp; Privacy" FontFamily="PoppinsBold" FontSize="20" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Grid>
        </VerticalStackLayout>

        <!-- Fields Area (White Bottom Container) -->
        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" Margin="0,-25,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30,30,0,0"/>
            </Border.StrokeShape>

            <ScrollView Padding="25,35,25,25">
                <VerticalStackLayout Spacing="30">

                    <!-- Account Security Section -->
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Account Security" FontFamily="PoppinsBold" FontSize="18" TextColor="Black"/>
                        
                        <VerticalStackLayout Spacing="15" Padding="5,0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="New Password" FontFamily="PoppinsBold" FontSize="14" TextColor="#757575"/>
                                <Border Stroke="#EEEEEE" StrokeThickness="1" Padding="10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Entry x:Name="PasswordEntry" FontFamily="PoppinsRegular" IsPassword="True" Placeholder="Enter new password" PlaceholderColor="#9E9E9E" TextColor="Black"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Confirm Password" FontFamily="PoppinsBold" FontSize="14" TextColor="#757575"/>
                                <Border Stroke="#EEEEEE" StrokeThickness="1" Padding="10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Entry x:Name="ConfirmPasswordEntry" FontFamily="PoppinsRegular" IsPassword="True" Placeholder="Confirm new password" PlaceholderColor="#9E9E9E" TextColor="Black"/>
                                </Border>
                            </VerticalStackLayout>

                            <Button Text="Update Password" FontFamily="PoppinsBold" FontSize="16" BackgroundColor="#FF8C00" TextColor="White" CornerRadius="20" HeightRequest="50" Margin="0,10,0,0" Clicked="OnChangePasswordClicked"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Account Actions Section -->
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Account Actions" FontFamily="PoppinsBold" FontSize="18" TextColor="Black"/>
                        
                        <VerticalStackLayout Spacing="12">
                            <Button Text="Deactivate Account" FontFamily="PoppinsBold" FontSize="14" BackgroundColor="#FFAB40" TextColor="White" CornerRadius="20" HeightRequest="50" Clicked="OnDeactivateClicked"/>
                            <Button Text="Delete Account Permanently" FontFamily="PoppinsBold" FontSize="14" BackgroundColor="#FF3B30" TextColor="White" CornerRadius="20" HeightRequest="50" Clicked="OnDeleteClicked"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Meowbook.Views"
             x:Class="Meowbook.Views.MessagesPage"
             BackgroundColor="#F5F5F5"
             Shell.NavBarIsVisible="False">
             
    <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" Padding="16,14,16,10" BackgroundColor="White">
            <Label Text="Messages" FontSize="26" FontAttributes="Bold" TextColor="#1A1A2E" VerticalOptions="Center"/>
        </Grid>
        
        <ScrollView Grid.Row="1">
            <StackLayout Padding="20" HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="No new messages." TextColor="#888" HorizontalOptions="Center" />
            </StackLayout>
        </ScrollView>

        <views:BottomNavBar Grid.Row="2" ActiveTab="Friends"/>
    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meowbook.Views.EditProfilePage"
             BackgroundColor="#F5F5F5"
             Title="Edit Profile">
             
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            
            <Label Text="Public Information" FontSize="18" FontAttributes="Bold"/>
            
            <Frame Padding="15" CornerRadius="10" BorderColor="Transparent">
                <VerticalStackLayout Spacing="15">
                    <VerticalStackLayout>
                        <Label Text="Name" FontSize="14" TextColor="#888" FontAttributes="Bold"/>
                        <Entry x:Name="NameEntry" Placeholder="Your Name"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout>
                        <Label Text="Username" FontSize="14" TextColor="#888" FontAttributes="Bold"/>
                        <Entry x:Name="UsernameEntry" Placeholder="Username" />
                    </VerticalStackLayout>
                    <VerticalStackLayout>
                        <Label Text="Birthdate" FontSize="14" TextColor="#888" FontAttributes="Bold"/>
                        <DatePicker x:Name="BirthdatePicker" Format="yyyy-MM-dd" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Profile Avatar" FontSize="14" TextColor="#888" FontAttributes="Bold"/>
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <Entry x:Name="AvatarEntry" Placeholder="Profile Image URL or Path" VerticalOptions="Center"/>
                            <Button Grid.Column="1" Text="Choose Photo" Clicked="OnChooseAvatarClicked" BackgroundColor="#E1F5FE" TextColor="#1DA1F2" CornerRadius="10" Padding="15,0"/>
                        </Grid>
                        <Border x:Name="AvatarPreviewContainer" StrokeThickness="2" HeightRequest="100" WidthRequest="100" HorizontalOptions="Start" Stroke="#1DA1F2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="50"/>
                            </Border.StrokeShape>
                            <Image x:Name="AvatarPreviewImage" Aspect="AspectFill" BackgroundColor="#F0F0F0" />
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout>
                        <Label Text="About Me (Bio)" FontSize="14" TextColor="#888" FontAttributes="Bold"/>
                        <Editor x:Name="BioEditor" Placeholder="Tell us about yourself..." HeightRequest="100"/>
                    </VerticalStackLayout>
                    <Button Text="Save Changes" BackgroundColor="#1DA1F2" TextColor="White" Clicked="OnSaveClicked" Margin="0,15,0,0"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

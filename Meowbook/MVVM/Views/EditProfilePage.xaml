<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meowbook.Views.EditProfilePage"
             BackgroundColor="#F5F5F5"
             Shell.NavBarIsVisible="False">
             
    <Grid RowDefinitions="Auto, *">
        <!-- Header Section (Orange) -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="#FF8C00" Padding="20,30,20,30" Spacing="20">
            <Grid ColumnDefinitions="40, *, 40">
                <ImageButton Grid.Column="0" Source="back.png" HeightRequest="20" WidthRequest="20" Clicked="OnBackClicked" BackgroundColor="Transparent" Padding="0" HorizontalOptions="Start"/>
                <Label Grid.Column="1" Text="Profile" FontFamily="PoppinsBold" FontSize="20" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Grid>

            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Border Padding="0" HeightRequest="120" WidthRequest="120" StrokeThickness="4" Stroke="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="60"/>
                    </Border.StrokeShape>
                    <Image x:Name="AvatarPreviewImage" Aspect="AspectFill" Source="profileplaceholder.png"/>
                </Border>
                <Label x:Name="CurrentNameLabel" Text="Martin Kantor" FontFamily="PoppinsBold" FontSize="18" TextColor="White" HorizontalOptions="Center"/>
                <Label x:Name="CurrentUsernameLabel" Text="@martin.kantor" FontFamily="PoppinsRegular" FontSize="14" TextColor="#E0E0E0" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                <Button Text="Upload Photo" FontFamily="PoppinsBold" FontSize="13" BackgroundColor="White" TextColor="#FF8C00" CornerRadius="10" HeightRequest="35" Padding="15,0" Clicked="OnChooseAvatarClicked"/>
                <Button Text="Add URL" FontFamily="PoppinsBold" FontSize="13" BackgroundColor="Transparent" TextColor="White" BorderColor="White" BorderWidth="1" CornerRadius="10" HeightRequest="35" Padding="15,0" Clicked="OnUrlAvatarClicked"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Fields Area (White Bottom Container) -->
        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" Margin="0,-25,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30,30,0,0"/>
            </Border.StrokeShape>
            
            <ScrollView Padding="25,35,25,25">
                <VerticalStackLayout Spacing="25">
                    
                    <!-- Label on left, Entry on right style -->
                    <Grid ColumnDefinitions="120, *" RowDefinitions="Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Full Name" FontFamily="PoppinsRegular" FontSize="14" TextColor="#757575" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" x:Name="NameEntry" FontFamily="PoppinsRegular" FontSize="15" TextColor="Black" HorizontalOptions="EndAndExpand" HorizontalTextAlignment="End"/>
                        <BoxView Grid.Row="0" Grid.ColumnSpan="2" HeightRequest="1" Color="#EEEEEE" VerticalOptions="End"/>
                    </Grid>

                    <Grid ColumnDefinitions="120, *" RowDefinitions="Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Username" FontFamily="PoppinsRegular" FontSize="14" TextColor="#757575" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" x:Name="UsernameEntry" FontFamily="PoppinsRegular" FontSize="15" TextColor="Black" HorizontalOptions="EndAndExpand" HorizontalTextAlignment="End"/>
                        <BoxView Grid.Row="0" Grid.ColumnSpan="2" HeightRequest="1" Color="#EEEEEE" VerticalOptions="End"/>
                    </Grid>

                    <Grid ColumnDefinitions="120, *" RowDefinitions="Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Birthdate" FontFamily="PoppinsRegular" FontSize="14" TextColor="#757575" VerticalOptions="Center"/>
                        <DatePicker Grid.Column="1" x:Name="BirthdatePicker" FontFamily="PoppinsRegular" FontSize="15" Format="yyyy-MM-dd" TextColor="Black" HorizontalOptions="EndAndExpand"/>
                        <BoxView Grid.Row="0" Grid.ColumnSpan="2" HeightRequest="1" Color="#EEEEEE" VerticalOptions="End"/>
                    </Grid>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Bio" FontFamily="PoppinsRegular" FontSize="14" TextColor="#757575"/>
                        <Border Stroke="#EEEEEE" StrokeThickness="1" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Editor x:Name="BioEditor" FontFamily="PoppinsRegular" FontSize="15" TextColor="Black" MinimumHeightRequest="80" AutoSize="TextChanges"/>
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Save Changes" FontFamily="PoppinsBold" FontSize="16" BackgroundColor="#FF8C00" TextColor="White" CornerRadius="20" HeightRequest="50" Margin="0,15,0,0" Clicked="OnSaveClicked"/>
                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>

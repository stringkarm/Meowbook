<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Meowbook.ViewModels"
             xmlns:models="clr-namespace:Meowbook.Models"
             xmlns:views="clr-namespace:Meowbook.Views"
             x:DataType="vm:HomeViewModel"
             x:Class="Meowbook.Views.HomePage"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*, Auto" Padding="16,0">
            <HorizontalStackLayout VerticalOptions="Center" Spacing="6" >
                <Image Source="logo.jpg" HeightRequest="28" WidthRequest="28" Aspect="AspectFit"/>
                <Label Text="Meowbook" FontSize="28" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                <Ellipse Fill="#FFFFFF" HeightRequest="8" WidthRequest="8" VerticalOptions="Center" Margin="2,8,0,0"/>
            </HorizontalStackLayout>

            <Frame Grid.Column="1" Padding="0" HeightRequest="40" WidthRequest="40" CornerRadius="20" IsClippedToBounds="True" BorderColor="#FF8C00" VerticalOptions="Center">
                <Image Source="{Binding LoggedInUserProfileImage}" Aspect="AspectFill"/>
            </Frame>
        </Grid>
    </Shell.TitleView>



    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" Margin="10,0" ColumnDefinitions="*, Auto" IsVisible="{Binding IsSearching}">
            <SearchBar Text="{Binding SearchText}" Placeholder="Search Meows..." SearchCommand="{Binding PerformSearchCommand}" Margin="0,0,10,0"/>
            <Button Grid.Column="1" Text="X" Command="{Binding ToggleSearchCommand}" VerticalOptions="Center"/>
        </Grid>

        <RefreshView Grid.Row="1"
                     Command="{Binding LoadPostsCommand}"
                     IsRefreshing="{Binding IsBusy}"
                     RefreshColor="#FF8C00">

            <CollectionView ItemsSource="{Binding Posts}" 
                            VerticalOptions="FillAndExpand">

                <CollectionView.Header>
                    <VerticalStackLayout Spacing="0" Padding="0,8,0,0">
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Padding="16,0">
                            <HorizontalStackLayout Spacing="12" BindableLayout.ItemsSource="{Binding Posts}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:Post">
                                        <Grid HeightRequest="160" WidthRequest="100">
                                            <!-- Story Background Image -->
                                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12">
                                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" BackgroundColor="#CCCCCC"/>
                                            </Border>

                                            <!-- Gradient overlay for text readability -->
                                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#44000000"/>

                                            <!-- User Avatar Top Left -->
                                            <Frame Padding="0" HeightRequest="36" WidthRequest="36" CornerRadius="18" 
                                                   IsClippedToBounds="True" BorderColor="#1DA1F2" HorizontalOptions="Start" VerticalOptions="Start" Margin="8">
                                                <Image Source="{Binding UserAvatar}" Aspect="AspectFill"/>
                                            </Frame>

                                            <!-- User Name Bottom -->
                                            <Label Text="{Binding UserName}" TextColor="White" FontSize="11" FontAttributes="Bold" 
                                                   VerticalOptions="End" HorizontalOptions="Start" Margin="8" LineBreakMode="TailTruncation"/>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </ScrollView>
                        <BoxView HeightRequest="14" Color="Transparent"/>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Post">
                        <VerticalStackLayout BackgroundColor="White" Margin="0,0,0,12" Spacing="0">
                            <Grid ColumnDefinitions="Auto, *, Auto" Padding="16,14,16,10" ColumnSpacing="12">
                                <Frame Padding="0" HeightRequest="44" WidthRequest="44" CornerRadius="22" IsClippedToBounds="True" BorderColor="#FF8C00">
                                    <Image Source="{Binding UserAvatar}" Aspect="AspectFill"/>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding UserName}" FontAttributes="Bold" FontSize="15" TextColor="#1C1C1C"/>
                                    <Label Text="Traveler, Life Lover" FontSize="11" TextColor="#9E9E9E"/>
                                </VerticalStackLayout>

                                <ImageButton Grid.Column="2" Source="addfriend.png" HeightRequest="22" WidthRequest="22" BackgroundColor="Transparent" VerticalOptions="Center"/>
                            </Grid>

                            <Grid Margin="16,0">
                                <Border StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="230" BackgroundColor="#EEEEEE"/>
                                </Border>
                                <Border StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="#DDFFFFFF" Padding="7,6" HorizontalOptions="End" VerticalOptions="Start" Margin="0,10,10,0">
                                    <Image Source="bookmark_icon.png" HeightRequest="16" WidthRequest="16"/>
                                </Border>
                            </Grid>

                            <Grid ColumnDefinitions="Auto, Auto, Auto, *" Padding="16,10,16,6" ColumnSpacing="16">
                                <HorizontalStackLayout Spacing="5">
                                    <Image Source="hearticon.png" HeightRequest="20" WidthRequest="20"/>
                                    <Label Text="{Binding Likes}" FontAttributes="Bold" FontSize="13" TextColor="#1C1C1C" VerticalOptions="Center"/>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Column="1" Spacing="5">
                                    <Image Source="commenticon.png" HeightRequest="20" WidthRequest="20"/>
                                    <Label Text="57" FontSize="13" TextColor="#9E9E9E" VerticalOptions="Center"/>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Column="2" Spacing="5">
                                    <Image Source="shareicon.png" HeightRequest="20" WidthRequest="20"/>
                                    <Label Text="33" FontSize="13" TextColor="#9E9E9E" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Grid>

                            <Label Margin="16,0,16,16" LineBreakMode="WordWrap" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding UserName}" FontAttributes="Bold" TextColor="#1C1C1C"/>
                                        <Span Text=" "/>
                                        <Span Text="{Binding Content}" TextColor="#424242"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <BoxView HeightRequest="10" Color="Transparent"/>
                </CollectionView.Footer>
            </CollectionView>
        </RefreshView>

        <!-- General Bottom Nav Bar -->
        <views:BottomNavBar Grid.Row="1" ActiveTab="Home" VerticalOptions="End" />

    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Meowbook.ViewModels"
             x:Class="Meowbook.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <Image Source="loginpagebg.png" 
               Aspect="AspectFill" 
               HorizontalOptions="Fill" 
               VerticalOptions="Fill" />

        <VerticalStackLayout Spacing="15" 
                             Padding="30,40" 
                             VerticalOptions="End">

            <Border Stroke="White" 
                    StrokeThickness="0.5"
                    BackgroundColor="#40FFFFFF">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Entry Placeholder="Username" 
                       PlaceholderColor="#E0E0E0"
                       Text="{Binding Username}" 
                       HeightRequest="55" 
                       TextColor="White"
                       HorizontalTextAlignment="Start"
                       Margin="15,0"
                       Keyboard="Plain"/>
            </Border>

            <Border Stroke="White" 
                    StrokeThickness="0.5"
                    BackgroundColor="#40FFFFFF">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                <Grid ColumnDefinitions="*, 50">
                    <Entry x:Name="LoginPasswordEntry"
                           Grid.Column="0"
                           Placeholder="Password" 
                           PlaceholderColor="#E0E0E0"
                           Text="{Binding Password}" 
                           IsPassword="True" 
                           HeightRequest="55" 
                           TextColor="White"
                           Margin="15,0"/>

                    <ImageButton x:Name="PasswordVisibilityButton"
                                 Grid.Column="1"
                                 Source="seepassword.png"
                                 BackgroundColor="Transparent"
                                 HeightRequest="24" 
                                 WidthRequest="24"
                                 Opacity="1" 
                                 Aspect="AspectFit"
                                 Margin="-12,3,0,0"
                                 VerticalOptions="Center" 
                                 HorizontalOptions="Center"
                                 Clicked="OnToggleLoginPasswordClicked" />
                </Grid>
            </Border>

            <Label Text="Forgot password?" 
                   TextColor="White" 
                   HorizontalOptions="End" 
                   FontFamily="PoppinsMedium">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <Button Text="Sign In" 
                    Command="{Binding LoginCommand}"
                    BackgroundColor="#FF8C00" 
                    TextColor="White"
                    HeightRequest="60" 
                    CornerRadius="15" 
                    Margin="0,10" 
                    FontFamily="PoppinsMedium">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.3" />
                </Button.Shadow>
            </Button>

            <Label Text="Or sign in with" 
                   HorizontalOptions="Center" 
                   TextColor="White" 
                   FontFamily="InterRegular"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="30" Margin="0,10">
                <ImageButton Source="search.png" HeightRequest="40" WidthRequest="40" />
                <ImageButton Source="facebook.png" HeightRequest="40" WidthRequest="40" />
            </HorizontalStackLayout>

            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,0,0,20">
                <Label Text="Don't have an account? " TextColor="White" VerticalOptions="Center" />
                <Label Text="Sign Up" 
                       TextColor="White" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center"
                       Padding="10,10">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="White"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>
</ContentPage>
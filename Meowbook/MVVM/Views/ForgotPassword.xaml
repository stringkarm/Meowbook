<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meowbook.Views.ForgotPassword"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="180, *">
        <BoxView Grid.Row="0" BackgroundColor="#FF8C00" />
        <Label Grid.Row="0" Text="Change Password" FontFamily="PoppinsBold"
               TextColor="White" FontSize="28" FontAttributes="Bold"
               HorizontalOptions="Center" VerticalOptions="Center" />

        <Frame Grid.Row="1" Margin="0,-30,0,0" CornerRadius="30" Padding="30" BorderColor="LightGray" HasShadow="True" BackgroundColor="White">
            <VerticalStackLayout Spacing="20">
                <Label Text="Enter your registered email to reset your password." 
                       TextColor="Gray" HorizontalTextAlignment="Center" FontFamily="InterRegular"/>

                <Border Stroke="#FF8C00">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12,12,12,12" />
                    </Border.StrokeShape>
                    <Entry x:Name="EmailEntry" Placeholder="Email Address" HeightRequest="55" />
                </Border>

                <Border Stroke="#FF8C00">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12,12,12,12" />
                    </Border.StrokeShape>
                    <Entry x:Name="NewPasswordEntry" Placeholder="New Password" IsPassword="True" HeightRequest="55" />

                </Border>
                
                <Button Text="Update Password" FontFamily="PoppinsMedium"
                        BackgroundColor="#FF8C00" TextColor="White"
                        HeightRequest="60" CornerRadius="12"
                        Clicked="OnUpdatePasswordClicked" />
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
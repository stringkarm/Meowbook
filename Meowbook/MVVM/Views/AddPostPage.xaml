<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meowbook.Views.AddPostPage"
             BackgroundColor="White"
             Title="New Post">
             
    <Grid RowDefinitions="Auto,*,Auto" Padding="16">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Text="Cancel" BackgroundColor="Transparent" TextColor="Black" Clicked="OnCancelClicked"/>
            <Label Grid.Column="1" Text="New Post" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Button Grid.Column="2" Text="Post" BackgroundColor="#1DA1F2" TextColor="White" CornerRadius="15" Clicked="OnPostClicked" x:Name="PostBtn"/>
        </Grid>
        
        <VerticalStackLayout Grid.Row="1" Spacing="15" Margin="0,20,0,0">
            <Editor x:Name="ContentEditor" Placeholder="What's happening?" PlaceholderColor="Gray" TextColor="Black" AutoSize="TextChanges" FontSize="18" HeightRequest="150" />
            
            <Label Text="Add Media" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0" TextColor="#1DA1F2" />
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                <Entry x:Name="ImageUrlEntry" Placeholder="Image URL or Path" PlaceholderColor="Gray" TextColor="Black" VerticalOptions="Center"/>
                <Button Grid.Column="1" Text="Choose File" Clicked="OnChooseImageClicked" BackgroundColor="#E1F5FE" TextColor="#1DA1F2" CornerRadius="10" Padding="15,0"/>
            </Grid>

            <Border x:Name="ImagePreviewContainer" StrokeThickness="0" HeightRequest="200" IsVisible="false" BackgroundColor="#F0F0F0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Image x:Name="PreviewImage" Aspect="AspectFill" />
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>

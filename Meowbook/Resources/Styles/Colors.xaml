<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#FF8C00</Color>
    <Color x:Key="PrimaryDark">#E07B00</Color>
    <Color x:Key="Secondary">#FFD700</Color>
    <Color x:Key="YellowOrange">#FFA500</Color>
    <Color x:Key="MeowBlack">#1C1C1C</Color>
    <Color x:Key="MainBackgroundGray">#F5F5F5</Color>

    <Color x:Key="Magenta">#FF00FF</Color>
    <Color x:Key="OffBlack">#1F1F1F</Color>
    <Color x:Key="OffWhite">#F1F1F1</Color>
    <Color x:Key="MidnightBlue">#191970</Color>
    <Color x:Key="PrimaryDarkText">#212121</Color>
    <Color x:Key="SecondaryDarkText">#424242</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C2C2C2</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#121212</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
</ResourceDictionary>